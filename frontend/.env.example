# Backend API URL. Set to your Fly.io backend URL after deploying.
# Leave empty for local dev (Vite proxies /api and /track to localhost:3001).
VITE_API_URL=

# Supabase project (frontend uses the ANON key — safe to expose in the browser).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
